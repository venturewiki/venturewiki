rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEditor() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['editor', 'admin'];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Users collection ──────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone signed in can read user profiles
      allow read: if isSignedIn();
      // Users can write their own doc; admins can write any
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Businesses collection ─────────────────────────────────────────────────
    match /businesses/{businessId} {
      // Public businesses readable by all; private only by signed-in users
      allow read: if resource.data.isPublic == true ||
                     isSignedIn();

      // Any signed-in editor can create a business
      allow create: if isEditor() &&
                       request.resource.data.createdBy == request.auth.uid;

      // Editors who are contributors OR admins can update
      allow update: if isAdmin() ||
                       (isEditor() &&
                        request.auth.uid in resource.data.contributors);

      // Only admins can hard-delete (soft-delete via isArchived is an update)
      allow delete: if isAdmin();
    }

    // ── Edits collection (revision history) ──────────────────────────────────
    match /edits/{editId} {
      allow read: if isSignedIn();
      // Only server-side writes via batch (no direct client writes)
      allow create: if isEditor();
      allow update, delete: if isAdmin();
    }

    // ── Comments collection ───────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isEditor() &&
                       request.resource.data.userId == request.auth.uid;
      // Authors can edit their own comments; admins can edit any
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── Everything else — deny by default ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
